<Window x:Class="Formulario_WPF.MainWindow"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:wf="clr-namespace:Microsoft.Reporting.WinForms;assembly=Microsoft.ReportViewer.WinForms"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Formulario_WPF"
        mc:Ignorable="d"
        Title="Introducción de Datos de Empleados" Height="1024" Width="1024"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Titulo -->
            <TextBlock Text="Introducción de Datos de Empleados"
                       FontSize="24"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Nombre -->
                <TextBlock Grid.Column="0" Grid.Row="0" 
                           Text="Nombre*" 
                           VerticalAlignment="Center"
                           Margin="0,5,0,5"/>
                <TextBox x:Name="txtNombre"
                         Grid.Column="1" Grid.Row="0"
                         Height="25" 
                         Margin="0,5,0,5"/>

                <!-- Apellidos -->
                <TextBlock Grid.Column="0" Grid.Row="1" 
                           Text="Apellidos*" 
                           VerticalAlignment="Center"
                           Margin="0,5,0,5"/>

                <TextBox x:Name="txtApellido"
                         Grid.Column="1" Grid.Row="1"
                         Height="25" 
                         Margin="0,5,0,5"/>

                <!-- Email -->
                <TextBlock Grid.Column="0" Grid.Row="2" 
                           Text="E-mail*" 
                           VerticalAlignment="Center"
                           Margin="0,5,0,5"/>

                <TextBox x:Name="txtEmail"
                         Grid.Column="1" Grid.Row="2"
                         Height="25" 
                         Margin="0,5,0,5"/>

                <!-- Telefono -->
                <TextBlock Grid.Column="0" Grid.Row="3" 
                           Text="Teléfono*" 
                           VerticalAlignment="Center"
                           Margin="0,5,0,5"/>

                <TextBox x:Name="txtTelefono"
                         Grid.Column="1" Grid.Row="3"
                         Width="180" Height="25" 
                         HorizontalAlignment="Left"
                         Margin="0,5,0,5"/>

                <!-- Fecha de nacimiento -->
                <TextBlock Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="2"
                           Text="Fecha de nacimiento" 
                           VerticalAlignment="Center"
                           Margin="0,5,10,5"/>

                <DatePicker x:Name="dpFechaNacimiento"
                         Grid.Column="1" Grid.Row="4"
                         Width="330" Height="30" 
                         HorizontalAlignment="Right"
                         Margin="0,5,0,5"/>

                <!-- DNI -->
                <StackPanel Grid.Column="0" Grid.Row="5" Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="DNI*" 
                               VerticalAlignment="Center"/>

                    <TextBox x:Name="txtDNI"
                             Grid.Column="1" Grid.Row="5" Grid.ColumnSpan="2"
                             Width="300" Height="25" 
                             Margin="10,0,0,0"/>

                </StackPanel>

                <!-- Boton para cargar Fotografia -->
                <TextBlock Grid.Column="0" Grid.Row="6" Grid.ColumnSpan="2"
                           Text="Adjuntar fotografía"
                           Width="110"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="0,12,10,5"/>

                <StackPanel Grid.Column="1" Grid.Row="6"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Height="100"
                            Margin="0,5,0,10">

                    <Button x:Name="btnCargarFoto"
                            Content="Cargar Foto"
                            Width="150" Height="45"
                            Margin="0,0,140,0"
                            Click="btnCargarFoto_Click"/>

                </StackPanel>

                <!-- Imagen para cargar la foto -->
                <StackPanel Grid.Column="2" Grid.Row="6"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,5,0,10">

                    <Image x:Name="imgFoto"
                           Width="150"
                           Height="150"
                           Stretch="Uniform"/>

                </StackPanel>

                <!-- Domicilio -->
                <TextBlock Grid.Column="0" Grid.Row="7"
                           Text="Domicilio" 
                           Margin="0,10,10,5"
                           VerticalAlignment="Top"/>

                <Grid Grid.Column="1" Grid.Row="7" Margin="0,5,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="txtDireccion"
                             Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2"
                             Height="25" 
                             Margin="15,2,0,0"
                             Text="Dirección"
                             GotFocus="Txt_GotFocus"
                             LostFocus="Txt_LostFocus"/>

                    <TextBox x:Name="txtCiudad"
                             Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                             Height="25" 
                             Margin="15,2,0,0"
                             Text="Ciudad"
                             GotFocus="Txt_GotFocus"
                             LostFocus="Txt_LostFocus"/>

                    <TextBox x:Name="txtProvincia"
                             Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2"
                             Height="25" 
                             Margin="15,2,0,0"
                             Text="Provincia"
                             GotFocus="Txt_GotFocus"
                             LostFocus="Txt_LostFocus"/>

                    <TextBox x:Name="txtCodigoPostal"
                             Grid.Column="0" Grid.Row="3" Grid.ColumnSpan="2"
                             Height="25" 
                             Margin="15,2,0,0"
                             Text="Código Postal"
                             GotFocus="Txt_GotFocus"
                             LostFocus="Txt_LostFocus"/>

                    <TextBox x:Name="txtPais"
                             Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="2"
                             Height="25" 
                             Margin="15,2,0,0"
                             Text="País"
                             GotFocus="Txt_GotFocus"
                             LostFocus="Txt_LostFocus"/>

                </Grid>

                <!-- Imagen con el logo del instituto -->
                <StackPanel Grid.Column="2" Grid.Row="7"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom">

                    <Image Source="/Images/logo.png"
                           Width="200"
                           Margin="150,0,0,20"
                           Stretch="Uniform"/>
                </StackPanel>

                <!-- Enlace a la red social -->
                <TextBlock Grid.Column="0" Grid.Row="8"
                           Grid.ColumnSpan="2"
                           Text="Enlace a red social"
                           VerticalAlignment="Center"
                           Margin="0,20,10,5"/>

                <TextBox Grid.Column="1" Grid.Row="8"  
                         Grid.ColumnSpan="2"
                         x:Name="txtRedSocial"
                         Height="25"
                         Margin="50,20,0,5"/>

                <!-- Rol actual -->
                <TextBlock Grid.Column="0" Grid.Row="9"
                           Text="Rol actual"
                           VerticalAlignment="Center"
                           Margin="0,10,10,5"/>
                <ComboBox Grid.Column="1" Grid.Row="9"
                          x:Name="cbRol"
                          Width="350"
                          Height="25"
                          Margin="50,10,0,5">

                    <ComboBoxItem Content="Desarrollador"/>
                    <ComboBoxItem Content="Analista"/>
                    <ComboBoxItem Content="Diseñador"/>
                    <ComboBoxItem Content="Administrador"/>

                </ComboBox>

                <!-- Descripcion del puesto actual -->
                <TextBlock Grid.Column="0" Grid.Row="10" Grid.ColumnSpan="2"
                           Text="Descripción del puesto de trabajo actual:"
                           VerticalAlignment="Top"
                           Margin="0,10,0,10"/>

                <TextBox Grid.Column="0" Grid.Row="11" Grid.ColumnSpan="3"
                         x:Name="txtDescripcion"
                         Height="100"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Botones para guardar o cancelar -->
                <StackPanel Grid.Column="0" Grid.Row="12" Grid.ColumnSpan="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,0">

                    <Button x:Name="btnGuradar"
                            Content="Guardar"
                            Width="100"
                            Height="40"
                            Margin="100,0,10,0"
                            Click="btnGuardar_Click"/>

                    <Button x:Name="btnCancelar"
                            Content="Cancelar"
                            Width="100"
                            Height="40"
                            Margin="0,0,10,0"
                            Click="btnCancelar_Click"/>

                    <Button x:Name="btnGenerarInforme"
                            Content="Generar Informe"
                            Width="150"
                            Height="40"
                            Click="btnGenerarInforme_Click"/>

                </StackPanel>
            </Grid>

            <!-- Data Grid -->
            <DataGrid x:Name="dgEmpleados"
                      Margin="0,10,0,10"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Height="150"
                      CanUserAddRows="False">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Nombre"
                                        Binding="{Binding Nombre}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Apellidos"
                                        Binding="{Binding Apellido}"
                                        Width="*"/>

                    <DataGridTextColumn Header="DNI"
                                        Binding="{Binding DNI}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Email"
                                        Binding="{Binding Email}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Teléfono"
                                        Binding="{Binding Telefono}"
                                        Width="*"/>

                </DataGrid.Columns>
            </DataGrid>

            <wfi:WindowsFormsHost Height="400">
                <wf:ReportViewer x:Name="reportViewer"/>
            </wfi:WindowsFormsHost>

        </StackPanel>
    </ScrollViewer>
</Window>
